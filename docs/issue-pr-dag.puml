' LAYER 1: Core Features (Layer 0 完了後に unblock)
' ============================================================
package "Layer 1: コア機能 (Migration 依存)" #EAF4FB {

  rectangle "#48\nfeat: Discord OAuth\nPPAL Identity Hub" as I48 #5BA8D8
  rectangle "PR #55\nDiscord OAuth\n→ AI Review ❌\nCRITICAL: CSRF・secret reuse" as PR55 #B3D4E8

  rectangle "#49\nfeat: Teachable Webhook\n→ LINE LIFF 案内" as I49 #5BA8D8
  rectangle "PR #56\nTeachable Webhook\n→ AI Review ❌\nCRITICAL: secret in query" as PR56 #B3D4E8
}

' ============================================================
' LAYER 2: Security Fixes (Layer 1 の問題修正)
' ============================================================
package "Layer 2: セキュリティ修正 (Layer 1 依存)" #FFF8E1 {

  rectangle "#67\nfix: Discord OAuth\nCSRF・認証バイパス修正" as I67 #E89020
  rectangle "#68\nfix: Teachable Webhook\n認証・冪等性・DB順序修正" as I68 #E89020

  note bottom of I67
