  rectangle "PR #53\nCopilot T38\n→ AI Review ❌\nCONSENT 未永続化" as PR53 #C8E6C9

  rectangle "#44\nfix: /health version\nbuild-time 注入" as I44 #6DBF6D
  rectangle "PR #40\nCopilot /health\n→ AI Review ❌\npackage.json bundled" as PR40 #C8E6C9

  rectangle "PR #50\nmanual impl\n/health+consent+plan\n(CI pending)" as PR50 #A5D6A7

