@startuml line-harness-oss-issue-pr-dag
title みやびライン — Issue/PR 依存関係 DAG (2026-03-26)

skinparam backgroundColor #F8F9FA
skinparam defaultFontSize 13
skinparam ArrowColor #444444
skinparam ArrowThickness 2
skinparam linetype ortho
skinparam nodesep 35
skinparam ranksep 55
skinparam rectangle {
  RoundCorner 12
  BorderThickness 2
  Padding 10
}
skinparam package {
  BorderThickness 2.5
  FontSize 13
  FontStyle bold
  Padding 16
}

' ============================================================
' LAYER 0: Foundation — Migration 011 (全後続タスクの前提)
' ============================================================
package "Layer 0: 基盤 Migration (ブロッカー)" #FDECEA {

  rectangle "#47\nfeat: unified_profiles\n移行 011" as I47 #E85454
  rectangle "PR #54\nCopilot v1\n(AFTER UPDATE trigger)\n→ AI Review ❌ CRITICAL" as PR54 #FFB3B3
  rectangle "PR #70\nCopilot v2\n(WHEN guard)\n→ AI Review ❌ CRITICAL" as PR70 #FFB3B3
  rectangle "PR #72\nCopilot v3\n(BEFORE UPDATE)\n→ CI pending" as PR72 #FFD580

  note right of PR54
    根本原因:
    ①コンテキスト未取得
    ②app の updated_at=?
    バインドパターン未確認
    ③AI Review が誤って
    trigger 追加を指示
  end note

  I47 -[#E85454,thickness=3]-> PR54 : Copilot\n自動実装
  PR54 -[#E85454,thickness=3]-> PR70 : fix Issue\n#60/#66
  PR70 -[#E85454,thickness=3]-> PR72 : fix Issue\n#71
