@startuml miyabi-line-replan
title みやびライン 復旧リプラン — 現在の進捗 (2026-03-26 updated)

top to bottom direction

skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 10
skinparam ArrowColor #555555
skinparam ArrowThickness 2
skinparam linetype ortho
skinparam nodesep 20
skinparam ranksep 40
skinparam rectangle {
  RoundCorner 8
  BorderThickness 1.5
  Padding 6
}
skinparam package {
  BorderThickness 2
  FontSize 11
  FontStyle bold
  Padding 10
}

' === 色 ===
' #6BCB77 = 完了
' #4D96FF = 実行中 / 進行中
' #FFD93D = 待機中
' #FF6B6B = クローズ対象
' #CCCCCC = クローズ済

' ============================================================
' PHASE 0: 即時クリーンアップ ✅ COMPLETE
' ============================================================

package "Phase 0: 即時クリーンアップ ✅ COMPLETE" #D4EDDA {
  rectangle "✅ PR#58 MERGED\ndocs: DAG / タスク分解" as P0_PR58 #6BCB77
  rectangle "✅ PR#63 CLOSED\nwatchdog superseded" as P0_PR63 #6BCB77
  rectangle "✅ I#51 CLOSED\ndocs test ephemeral" as P0_I51 #6BCB77
  rectangle "✅ I#57 CLOSED\nタスク整理 meta" as P0_I57 #6BCB77
}

' ============================================================
' PHASE 1: 誤り連鎖クリーンアップ ✅ COMPLETE
' ============================================================

package "Phase 1: 誤り連鎖クリーンアップ ✅ COMPLETE" #D4EDDA {
  rectangle "✅ PR#54 CLOSED\nmigration v1 (trigger)" as P1_PR54 #6BCB77
  rectangle "✅ PR#70 CLOSED\nmigration v2 (trigger)" as P1_PR70 #6BCB77
  rectangle "✅ PR#72 CLOSED\nmigration v3 (trigger)" as P1_PR72 #6BCB77
  rectangle "✅ I#60/#66/#71\nCLOSED 誤り方向" as P1_ISSUES #6BCB77
